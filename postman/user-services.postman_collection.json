        {
          "name": "Error - Usuario inexistente (404)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ghost@nowhere.com\",\n  \"rol\": \"admin_hotel\",\n  \"hotel_id\": \"{{hotel_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/users/promote",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "users", "promote"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Mensaje usuario no encontrado', () => {",
                  "  pm.expect(pm.response.json().detail).to.include('no encontrado');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
